  "scripts": {
    "//": "— Dev & quality —",
    "dev": "next dev",
    "dev:turbo": "next dev --turbopack",
    "start": "next dev",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "check": "tsc -p .",
    "migrate": "npx tsx scripts/migrations/migrate-sqlite.ts",
    "//2": "— OpenNext (Pages) — default path —",
    "build": "next build",
    "clean": "rimraf .next .open-next .turbo .vercel",
    "pages:create": "wrangler pages project create homepage --production-branch=main",
    "deploy:pages": "npm run nbuild && wrangler pages deploy .open-next",
    "predeploy:pages": "npm run clean",
    "pages:preview": "npm run nbuild && wrangler pages dev .open-next --local",
    "//3": "— Optional: single-Worker deploys using @opennextjs/cloudflare —",
    "deploy:worker": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "preview:worker": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "//4": "— Next-only helpers (kept for compatibility) —",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "nbuild": "open-next build --platform=cloudflare",
    "bstart": "npm run build && clear && next dev",
    "bnr": "next build && clear && next dev",
    "secret:generate": "openssl rand -base64 32",
    "secret:hex": "npx tsx scripts/generate-hex.ts",
    "secret:list": "npx tsx scripts/wrangler-secrets.ts list",
    "secret:put": "npx tsx scripts/wrangler-secrets.ts put",
    "secret:delete": "npx tsx scripts/wrangler-secrets.ts delete",
    "secret:get": "npx tsx scripts/wrangler-secrets.ts get",
    "//5": "— Drizzle —",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:pull": "drizzle-kit pull",
    "db:push": "node -r dotenv/config node_modules/drizzle-kit/bin.cjs push",
    "db:reset": "drizzle-kit push",
    "db:drop": "drizzle-kit drop",
    "db:update": "drizzle-kit generate && drizzle-kit migrate && drizzle-kit push",
    "db:test": "npx tsx scripts/test-db-connection.ts",
    "//6": "— Utilities/Scripts —",
    "clean-install": "rm -rf node_modules package-lock.json .next && npm install",
    "db:mark-applied": "npx tsx scripts/mark-migration-applied.ts",
    "db:apply-migration": "npx tsx scripts/apply-migration-drizzle.ts",
    "db:fix-proposals": "npx tsx scripts/add-proposals-columns.ts",
    "seed:all": "npx tsx scripts/seed-all.ts",
    "seed:core-skills": "npx tsx scripts/seed-core-skills.ts",
    "db:seed": "npm run db:push && npm run seed:all",
    "test:db": "npx tsx scripts/test-db-connection.ts",
    "reset:password": "npx tsx scripts/reset-admin-password.ts",
    "set:secrets": "node scripts/set-cloudflare-secrets.js",
    "tail": "node scripts/wrangler-tail.local.js",
    "//7": "— git —",
    "gitgraph": "git log --graph --decorate --oneline --all",
    "//8": "— Push and RLS —",
    "enable:rls": "npx tsx scripts/enable-rls.ts",
    "push:rls": "drizzle-kit push && npm run enable:rls",
    "migrate:rls": "drizzle-kit migrate && npm run enable:rls"
  },
  "imports": {
    "@/*": "./src/*",
    "#/*": "./*",
    "$/*": "./lib/*",
    "^/*": "./public/*"
  }
}
